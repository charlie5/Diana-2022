-- ===========================================================================
-- DIANA_2022.idl  —  Descriptive Intermediate Attributed Notation for Ada 2022
-- ---------------------------------------------------------------------------
-- An updated, backwards-compatible DIANA intermediate representation, written
-- in the Wulf/Lamb/Nestor IDL (NOT CORBA IDL).
--
-- STATUS: v0.1 CORE. Establishes the architecture, conventions, and a faithful
--   core node set derived from the DIANA Rev 3 domain (see
--   references/DIANA_Rev3_node_attributes.md). The full Ada 2022 surface (tasks,
--   complete type system, contracts detail, parallelism, ...) is marked with
--   "TODO(2022)" extension points to be filled in subsequent passes.
--
-- CONVENTIONS
--   * Identifiers: Camel_Case, full words, initial capitals. The DIANA RM
--     class/node case distinction is dropped; classes and nodes are both
--     Camel_Case. Class productions use "::=", node attributes use "=>".
--   * NO attribute prefixes. Attributes are named by meaning; their kind is
--     shown by trailing comments (structural / lexical / semantic / code) — see
--     CLAUDE.md. This is a naming convention only, and is reversible.
--   * Single-parent hierarchy with shared attributes hoisted to the highest
--     applicable class (Rev 4 style). The universal lexical attributes live on
--     the root class Diana_Node.
--   * Provenance: each section cites the Ada 2022 RM clause and/or DIANA origin.
--     "[Ada 22 RM x.y]" = Ada 2022 Reference Manual; "[DIANA]" = carried over
--     from the historical DIANA design.
--   * Idioms: "_S" = sequence (Foo_S => List : Seq Of Foo);
--             "_Void" = optional (Foo_Void ::= Foo | Void).
--
-- The Rev 3/4 short node names are exposed separately via a "Renames"
-- compatibility structure (spec/DIANA_2022_Compatibility.idl — TODO).
-- ===========================================================================

Structure DIANA_2022 Root Diana_Node Is


    -- =======================================================================
    -- Private (implementation-defined) types                        [DIANA]
    -- Each DIANA user supplies an implementation; see Diana_Concrete refinement.
    -- =======================================================================

    Type Source_Position;  -- location of a node in the original source
    Type Comments;         -- comments attached to a node (source reconstruction)
    Type Symbol_Rep;       -- spelling of identifiers, strings, characters
    Type Value;            -- value of a static expression (or "no value")
    Type Number_Rep;       -- representation of a numeric literal


    -- =======================================================================
    -- Universal node base                                           [Rev 4]
    -- The single root class. Every node is (transitively) a member, so the
    -- universal lexical attributes below are inherited by all nodes.
    -- =======================================================================

    Diana_Node ::=
          Compilation
        | Compilation_Unit
        | Context_Element
        | All_Declaration
        | Defining_Occurrence
        | Type_Spec
        | Constraint
        | Header
        | Expression            -- Name is a subclass of Expression (see below)
        | Statement
        | Association
        | Semantic_Property
        | Element_List;         -- the "_S" sequence carriers (grouped, see end)

    Diana_Node =>
          Source_Position : Source_Position,  -- lexical
          Comments        : Comments;         -- lexical


    -- =======================================================================
    -- 10. Compilation units                                [Ada 22 RM 10.1]
    -- =======================================================================

    Compilation =>
          Units : Compilation_Unit_S;

    Compilation_Unit =>
          Context      : Context_Element_S,  -- structural
          Library_Item : All_Declaration;    -- structural (Void = a pragma-only unit)

    -- The declarative universe: declarations, bodies, and subunits (Rev 4 ALL_DECL).
    -- A compilation unit's library item is just one of these; which library items
    -- are legal is a semantic rule, not a structural one.
    All_Declaration ::= Item | Subunit;
    Item        ::= Declaration | Proper_Body | Entry_Body;
    Proper_Body ::= Subprogram_Body | Package_Body | Task_Body | Protected_Body;

    Context_Element ::=
          With_Clause
        | Context_Use_Clause
        | Context_Pragma;

    With_Clause =>             -- [Ada 22 RM 10.1.2]
          Names      : Name_S,
          Is_Limited : Boolean,             -- "limited with"
          Is_Private : Boolean;             -- "private with"


    -- =======================================================================
    -- 3.1 Declarations                                      [Ada 22 RM 3.1]
    -- =======================================================================

    Declaration ::=
          Object_Or_Number_Declaration
        | Identifier_Declaration
        | Representation_Clause
        | Use_Or_Pragma;

    -- Nested declaration classes — single parent per node  (Rev 4 DECL family).
    Object_Or_Number_Declaration ::= Object_Declaration | Number_Declaration;
    Object_Declaration           ::= Constant_Declaration | Variable_Declaration;
    Identifier_Declaration ::=
          Type_Declaration
        | Subtype_Declaration
        | Subprogram_Declaration
        | Package_Declaration
        | Task_Declaration
        | Generic_Declaration
        | Exception_Declaration
        | Deferred_Constant_Declaration
        | Renaming_Declaration
        | Generic_Instantiation;             -- "package X is new G(...)"  (single home)
    Use_Or_Pragma ::= Use_Clause | Declaration_Pragma;
    Declaration_Pragma => Pragma : Pragma;      -- a pragma in a declarative position

    -- Declarations / types that may carry aspects or attribute-definition
    -- clauses (semantic). Attached to these base classes for now; refine to
    -- exact Ada legality later. -- TODO(2022)
    Declaration => Properties : Semantic_Property_S;   -- semantic
    Type_Spec   => Properties : Semantic_Property_S;   -- semantic

    -- 3.3.1 objects and named numbers                     [Ada 22 RM 3.3.1]
    Constant_Declaration =>                     -- [Ada 22 RM 3.3.1]
          Names          : Defining_Name_S,  -- structural (the defined Constant_Names)
          Object_Subtype : Type_Spec,        -- structural
          Initialization : Expression;       -- structural (Void if none)
    Variable_Declaration =>
          Names          : Defining_Name_S,  -- structural (the defined Object_Names)
          Object_Subtype : Type_Spec,        -- structural
          Initialization : Expression;       -- structural (Void if none)

    -- Optional initializers/conditions are now typed Expression directly; the
    -- universal node Void stands in when absent. Object renamings are distinct
    -- Renaming_Declarations, not an init-slot variant.

    Number_Declaration =>
          Names                   : Defining_Name_S,  -- structural
          Static_Value_Expression : Expression;       -- structural (universal-typed)

    -- 3.2.1 type & subtype declarations                   [Ada 22 RM 3.2.1]
    Type_Declaration =>
          Name          : Defining_Name,      -- structural
          Discriminants : Discriminant_Part,  -- structural (Void if none)
          Definition    : Type_Spec;          -- structural

    Subtype_Declaration =>
          Name                    : Defining_Name,     -- structural
          Subtype_Mark_Constraint : Constrained_Spec;  -- structural

    Exception_Declaration =>                   -- [Ada 22 RM 11.1]
          Names : Defining_Name_S;

    Deferred_Constant_Declaration =>           -- [Ada 22 RM 7.4]
          Names        : Defining_Name_S,
          Subtype_Mark : Name;

    Use_Clause =>                              -- [Ada 22 RM 8.4]  (use / use type)
          Names : Name_S;

    Renaming_Declaration =>                    -- [Ada 22 RM 8.5]
          Renamed : Renaming;


    -- =======================================================================
    -- 3.2 Defining and used occurrences (the symbol table)          [DIANA]
    --   Each entity has exactly one Defining_Name carrying its semantic info.
    --   Used occurrences (a kind of Name) point back via Definition.
    -- =======================================================================

    Defining_Occurrence ::= Defining_Name | Defining_Operator | Defining_Character;

    -- Every defining occurrence carries its spelling (hoisted).      [lexical]
    Defining_Occurrence => Spelling : Symbol_Rep;

    -- A defining operator ("+", ...) is subprogram-like; a defining character
    -- literal is enumeration-literal-like.
    Defining_Operator =>                        -- def_op
          Specification    : Header,
          Completion       : Unit_Completion,
          Location         : Expression,
          Stub             : Defining_Occurrence,
          First_Definition : Defining_Occurrence;
    Defining_Character =>                        -- def_char
          Object_Type    : Type_Spec,
          Position       : Integer,
          Representation : Integer;

    Defining_Name ::= Source_Name | Predefined_Name;

    -- ----- Source-program defining names  (Rev 4 SOURCE_NAME) --------------
    Source_Name ::=
          Object_Name
        | Enumeration_Literal_Name
        | Type_Name
        | Unit_Name
        | Label_Name
        | Entry_Name
        | Exception_Name;

    -- objects, numbers, components, discriminants, parameters, loop parameters
    Object_Name      ::= Init_Object_Name | Iteration_Name;
    Init_Object_Name ::=
          Variable_Name | Constant_Name | Number_Name
        | Component_Name | Discriminant_Name | Parameter_Name;
    Variable_Name =>                             -- var_id
          Object_Type : Type_Spec,
          Address     : Expression,
          Object_Def  : Expression;
    Constant_Name =>                             -- const_id
          Object_Type      : Type_Spec,
          Address          : Expression,
          Object_Def       : Expression,
          First_Definition : Defining_Occurrence;  -- deferred constants
    Number_Name =>                               -- number_id (a universal type)
          Object_Type             : Type_Spec,
          Static_Value_Expression : Expression;
    Component_Name =>                            -- comp_id
          Object_Type    : Type_Spec,
          Initialization : Expression,     -- Void if none
          Component_Spec : Component_Rep;  -- Void if none
    Discriminant_Name =>                         -- dscrmt_id
          Object_Type      : Type_Spec,
          Initialization   : Expression,           -- Void if none
          First_Definition : Defining_Occurrence,
          Component_Spec   : Component_Rep;        -- Void if none
    Parameter_Name =>                            -- in_id / in_out_id / out_id
          Object_Type      : Type_Spec,
          Default          : Expression,           -- Void unless an 'in' default
          First_Definition : Defining_Occurrence;
    Iteration_Name =>                            -- iteration_id (a loop parameter)
          Object_Type : Type_Spec;

    Enumeration_Literal_Name =>                  -- enum_id
          Object_Type    : Type_Spec,
          Position       : Integer,    -- base-0 position
          Representation : Integer;    -- user-supplied rep value

    -- types
    Type_Name ::= Full_Type_Name | Subtype_Name | Private_Type_Name;
    Full_Type_Name =>                            -- type_id
          Type_Specification : Type_Spec,
          First_Definition   : Defining_Occurrence;  -- incomplete/full, multiple points
    Subtype_Name =>                              -- subtype_id
          Type_Specification : Constrained_Spec;
    Private_Type_Name =>                         -- private_type_id / l_private_type_id
          Type_Specification : Type_Spec;  -- the full view

    -- program units
    Unit_Name ::= Subprogram_Name | Package_Name | Generic_Name | Task_Body_Name;
    Subprogram_Name =>                           -- proc_id / function_id
          Specification    : Header,
          Completion       : Unit_Completion,
          Location         : Expression,
          Stub             : Defining_Occurrence,
          First_Definition : Defining_Occurrence;
    Package_Name =>                              -- package_id
          Specification    : Package_Specification,
          Completion       : Unit_Completion,
          Address          : Expression,
          Stub             : Defining_Occurrence,
          First_Definition : Defining_Occurrence;
    Generic_Name =>                              -- generic_id
          Formals          : Generic_Formal_S,
          Specification    : Generic_Header,
          Completion       : Unit_Completion,      -- Void under separate compilation
          Stub             : Defining_Occurrence,
          First_Definition : Defining_Occurrence;
    Task_Body_Name =>                            -- task_body_id
          Type_Specification : Type_Spec,
          Completion         : Unit_Completion,      -- Void under separate compilation
          Stub               : Defining_Occurrence,
          First_Definition   : Defining_Occurrence;

    -- labels, block/loop names
    Label_Name ::= Statement_Label_Name | Loop_Block_Name;
    Statement_Label_Name => Statement : Statement;  -- label_id; the labeled statement
    Loop_Block_Name      => Statement : Statement;  -- named_stm_id; named loop/block

    Entry_Name =>                                -- entry_id
          Specification : Header,
          Address       : Expression;
    Exception_Name =>                            -- exception_id
          First_Definition : Defining_Occurrence;  -- renaming / multiple decl points

    -- ----- Predefined-environment defining names  (Rev 4 PREDEF_NAME) ------
    Predefined_Name ::=
          Attribute_Name | Pragma_Name | Argument_Name | Builtin_Operator_Name;
    Attribute_Name        => ;                   -- attr_id (a predefined attribute)
    Pragma_Name           => Arguments : Defining_Name_S;  -- pragma_id (its Argument_Names)
    Argument_Name         => ;                   -- argument_id
    Builtin_Operator_Name => Operator : Operator;-- bltn_operator_id


    -- =======================================================================
    -- 4.1 / 4.4 Expressions and names                 [Ada 22 RM 4.1, 4.4]
    --   Name is a subclass of Expression. All operators and calls are
    --   Function_Call, except the short-circuit and membership forms. [DIANA]
    -- =======================================================================

    Expression ::=
          Name
        | Numeric_Literal
        | String_Literal
        | Null_Literal
        | Aggregate
        | Delta_Aggregate           -- (X with delta ...)         [Ada 22 RM 4.3.4]
        | Container_Aggregate       -- [ ... ] container aggregate [Ada 22 RM 4.3.5]
        | Allocator
        | Qualified_Expression
        | Type_Conversion
        | Parenthesized_Expression
        | Short_Circuit
        | Membership
        | Conditional_Expression    -- if-/case-expression         [Ada 22 RM 4.5.7]
        | Quantified_Expression     -- for all / for some          [Ada 22 RM 4.5.8]
        | Declare_Expression        -- (declare ... begin ...)      [Ada 22 RM 4.5.9]
        | Reduction_Expression      -- 'Reduce / 'Parallel_Reduce   [Ada 22 RM 4.5.10]
        | Raise_Expression;         -- (raise E with msg)          [Ada 22 RM 4.4]

    -- hoisted to all expressions
    Expression =>
          Expression_Type : Type_Spec,  -- semantic
          Static_Value    : Value;      -- semantic

    Numeric_Literal =>
          Literal_Image : Number_Rep;  -- lexical

    String_Literal =>
          Literal_Image : Symbol_Rep,  -- lexical
          Constraint    : Constraint;  -- semantic

    Null_Literal => ;                          -- the "null" access value

    Parenthesized_Expression =>
          Operand : Expression;

    Type_Conversion =>
          Target  : Name,
          Operand : Expression;

    Qualified_Expression =>
          Target  : Name,
          Operand : Expression;

    Allocator ::= Qualified_Allocator | Subtype_Allocator;   -- [Ada 22 RM 4.8]
    Qualified_Allocator => Value : Expression;               -- new T'(x)
    Subtype_Allocator   => Subtype_Indication : Constrained_Spec;  -- new T

    Aggregate =>
          Associations    : Association_S,  -- structural
          Square_Brackets : Boolean,        -- lexical  ([ ] vs ( ) array aggregate)
          Normalized      : Expression_S;   -- semantic

    Short_Circuit =>
          Left     : Expression,
          Operator : Short_Circuit_Op,
          Right    : Expression;
    Short_Circuit_Op ::= And_Then | Or_Else;
    And_Then => ;
    Or_Else  => ;

    Membership =>                               -- "X in C1 | C2 | ..."  [Ada 22 RM 4.4]
          Operand  : Expression,
          Operator : Membership_Op,
          Choices  : Membership_Choice_S;
    Membership_Choice  ::= Membership_Value | Membership_Range | Membership_Subtype;
    Membership_Value   => Value        : Expression;    -- a simple_expression choice
    Membership_Range   => Range        : Scalar_Range;  -- a range choice
    Membership_Subtype => Subtype_Mark : Name;          -- a subtype_mark choice
    Membership_Op ::= In_Set | Not_In_Set;
    In_Set     => ;
    Not_In_Set => ;

    -- ----- Ada 2012 / 2022 expression forms ----------------------------------

    -- Conditional expressions                               [Ada 22 RM 4.5.7]
    Conditional_Expression ::= If_Expression | Case_Expression;
    If_Expression =>
          Clauses : Expression_Clause_S;
    Expression_Clause =>
          Condition : Expression,  -- Void condition = the "else" result
          Result    : Expression;
    Case_Expression =>
          Selector     : Expression,
          Alternatives : Expression_Alternative_S;
    Expression_Alternative =>
          Choices : Choice_S,
          Result  : Expression;

    -- Quantified expressions                                [Ada 22 RM 4.5.8]
    Quantified_Expression =>
          Quantifier : Quantifier_Kind,
          Iterator   : Iterator_Specification,
          Predicate  : Expression;
    Quantifier_Kind ::= For_All | For_Some;
    For_All  => ;
    For_Some => ;

    -- Iterator specifications — shared by quantified expressions and the
    -- iterated associations in aggregates (loops may adopt this later).
    -- Ada 2022 adds the "when" iterator filter.          [Ada 22 RM 5.5, 4.3.3]
    Iterator_Specification ::= Range_Iterator | Container_Iterator;
    Range_Iterator =>                           -- "X in [reverse] discrete_range"
          Parameter      : Defining_Name,
          Discrete_Range : Discrete_Range,
          Reverse_Order  : Boolean,
          Filter         : Expression;      -- Void if no "when" filter
    Container_Iterator =>                        -- "X of [reverse] iterable"
          Parameter     : Defining_Name,
          Iterable      : Expression,
          Reverse_Order : Boolean,
          Filter        : Expression;     -- Void if no "when" filter

    -- Declare expressions                                   [Ada 22 RM 4.5.9]
    Declare_Expression =>
          Declarations : Declaration_S,  -- object / object-renaming declarations
          Result       : Expression;

    -- Reduction expressions ('Reduce / 'Parallel_Reduce)   [Ada 22 RM 4.5.10]
    Reduction_Expression =>
          Value_Sequence : Expression,  -- an array, iterable, or [ ... ] sequence
          Reducer        : Name,        -- the combiner subprogram
          Initial_Value  : Expression,
          Is_Parallel    : Boolean;     -- 'Parallel_Reduce vs 'Reduce

    -- Raise expressions                                      [Ada 22 RM 4.4]
    Raise_Expression =>
          Exception_Name : Name,
          Message        : Expression;  -- Void if no "with" message

    -- Delta aggregates                                      [Ada 22 RM 4.3.4]
    Delta_Aggregate =>
          Base   : Expression,     -- the base record/array value
          Deltas : Association_S;  -- component => value overrides

    -- Container aggregates ( [ ... ] , Aggregate aspect)   [Ada 22 RM 4.3.5]
    Container_Aggregate =>
          Associations : Association_S;  -- positional / keyed / iterated

    -- 4.1 names
    Name ::=
          Selector_Name             -- Used_Name | Used_Operator | Used_Character (see below)
        | Used_Object
        | Used_Builtin
        | Indexed_Component
        | Slice
        | Selected_Component
        | Dereference
        | Attribute_Reference
        | Attribute_Call
        | Function_Call
        | Target_Name;              -- "@" in an assignment RHS    [Ada 22 RM 5.2.1]

    -- semantic links (the symbol-table back-references)            [DIANA]
    Used_Name      => Definition       : Defining_Occurrence;  -- semantic
    Used_Object    => Definition       : Defining_Occurrence;  -- semantic (objects, enum literals, numbers)
    Used_Character => Definition       : Defining_Occurrence;  -- semantic
    Used_Operator  => Definition       : Defining_Occurrence;  -- semantic
    Used_Builtin   => Builtin_Operator : Operator;             -- semantic (predefined operators)

    Indexed_Component =>
          Prefix  : Name,
          Indices : Expression_S;

    Slice =>
          Prefix         : Name,
          Discrete_Range : Discrete_Range;

    Selected_Component =>
          Prefix   : Name,
          Selector : Selector_Name;
    Selector_Name ::= Used_Name | Used_Operator | Used_Character;

    Dereference =>                              -- name.all  [Ada 22 RM 4.1]
          Prefix : Name;

    Attribute_Reference =>
          Prefix    : Name,
          Attribute : Name;  -- a predefined Attribute_Name

    Attribute_Call =>
          Prefix   : Name,
          Argument : Expression;

    -- 6.4 calls and operators (one node for both)                 [DIANA]
    Function_Call =>
          Prefix             : Name,           -- structural
          Actuals            : Association_S,  -- structural
          Is_Prefix_Notation : Boolean,        -- lexical (infix vs. prefix; conformance)
          Normalized_Actuals : Expression_S;   -- semantic

    Target_Name => ;                            -- "@" : the assignment target  [Ada 22 RM 5.2.1]

    Association ::=                             -- parameter / aggregate associations
          Positional_Association
        | Named_Association
        | Iterated_Association;
    Positional_Association => Value : Expression;   -- a bare (positional) actual/value
    Named_Association      =>
          Choices : Choice_S,
          Actual  : Expression;
    Iterated_Association =>                      -- "for I in R => E" / "for E of A => f(E)"  [Ada 22 RM 4.3.3]
          Iterator : Iterator_Specification,
          Result   : Expression;


    -- =======================================================================
    -- 5. Statements                                         [Ada 22 RM 5.1]
    -- =======================================================================

    Statement ::=
          Null_Statement
        | Assignment
        | Procedure_Call
        | Exit_Statement
        | Return_Statement
        | Goto_Statement
        | If_Statement
        | Case_Statement
        | Loop_Statement
        | Block_Statement
        | Labeled_Statement
        | Raise_Statement
        | Delay_Statement
        | Accept_Statement          -- [Ada 22 RM 9.5.2]
        | Entry_Call                -- [Ada 22 RM 9.5.3]
        | Requeue_Statement         -- [Ada 22 RM 9.5.4]
        | Select_Statement          -- [Ada 22 RM 9.7]
        | Abort_Statement           -- [Ada 22 RM 9.8]
        | Parallel_Block            -- [Ada 22 RM 5.6.1]
        | Statement_Pragma;

    Null_Statement => ;

    Assignment =>
          Target : Name,
          Source : Expression;

    Procedure_Call =>
          Prefix             : Name,
          Actuals            : Association_S,
          Normalized_Actuals : Expression_S;   -- semantic

    Goto_Statement =>
          Target : Name;

    Delay_Statement =>                          -- [Ada 22 RM 9.6]
          Expression : Expression,
          Until_Form : Boolean;     -- "delay until" (absolute) vs "delay" (relative)

    Labeled_Statement =>
          Labels    : Defining_Name_S,
          Statement : Statement;

    -- 5.8 return: ONE node collapses simple "return X;", "return;", and the
    -- extended return "return R : T := X do ... end return;".        [Instr]
    Return_Statement =>
          Returned_Object    : Expression,   -- Void for "return;"
          Handled_Statements : Statement_S;  -- the "do ... end return"; empty if absent

    If_Statement =>
          Clauses : Conditional_Clause_S;
    Conditional_Clause =>
          Condition  : Expression,   -- Void condition = the "else" arm
          Statements : Statement_S;

    Case_Statement =>
          Selector     : Expression,
          Alternatives : Alternative_S;
    Alternative ::= Case_Alternative | Alternative_Pragma;
    Case_Alternative =>
          Choices    : Choice_S,
          Statements : Statement_S;

    Loop_Statement =>
          Iteration  : Iteration,
          Statements : Statement_S;
    Iteration ::=
          No_Iteration
        | While_Loop
        | For_Loop;
    No_Iteration => ;                           -- a bare "loop ... end loop"
    While_Loop   =>
          Condition : Expression;
    For_Loop =>                                 -- "for" / "for of" loops, optionally parallel
          Iterator : Iterator_Specification,     -- range or container; carries reverse + filter
          Parallelism : Parallel_Specification;  -- sequential, or parallel with chunking  [Ada 22 RM 5.5]
    Parallel_Specification ::= Sequential | Parallel_Chunked;
    Sequential       => ;
    Parallel_Chunked =>                         -- "parallel (chunk_specification) for ..."
          Chunk_Specification : Expression;  -- Void, a count, or a chunk discrete-range

    Block_Statement =>                          -- "[label:] declare ... begin ... end"
          Block : Block;  -- a block statement is a block (see Block)

    Exit_Statement =>
          Loop_Name : Name,        -- Void if unnamed
          Condition : Expression;  -- Void if no "when"

    Raise_Statement =>                          -- [Ada 22 RM 11.3]
          Exception_Name : Name,        -- Void for a re-raise ("raise;")
          Message        : Expression;  -- Void if no "with" message


    -- =======================================================================
    -- 9. Tasking and synchronization statements              [Ada 22 RM 9]
    --   (Entry declarations reuse Subprogram_Declaration with an Entry_Header;
    --    task/protected type specs are Type_Specs — see the type section.)
    -- =======================================================================

    Accept_Statement =>                         -- [Ada 22 RM 9.5.2]
          Entry_Name         : Name,           -- the accepted entry
          Entry_Index        : Expression,     -- Void unless an entry-family member
          Parameters         : Parameter_S,
          Handled_Statements : Statement_S,    -- the "do ... end"; empty if absent
          Handlers           : Alternative_S;  -- exception handlers in the accept body

    Entry_Call =>                               -- [Ada 22 RM 9.5.3]
          Prefix             : Name,           -- the called entry (indexed for a family)
          Actuals            : Association_S,
          Normalized_Actuals : Expression_S;   -- semantic

    Requeue_Statement =>                        -- [Ada 22 RM 9.5.4]
          Target     : Name,     -- the entry to requeue to
          With_Abort : Boolean;

    Abort_Statement =>                          -- [Ada 22 RM 9.8]
          Tasks : Name_S;

    -- 9.7 Select statements (all four forms)
    Select_Statement ::=
          Selective_Accept
        | Conditional_Entry_Call
        | Timed_Entry_Call
        | Asynchronous_Select;

    Selective_Accept =>                         -- [Ada 22 RM 9.7.1]
          Alternatives    : Select_Alternative_S,
          Else_Statements : Statement_S;           -- empty if no "else" part
    Select_Alternative ::=
          Accept_Alternative
        | Delay_Alternative
        | Terminate_Alternative
        | Select_Alternative_Pragma;
    Accept_Alternative =>
          Guard            : Expression,        -- "when C =>"; Void if no guard
          Accept_Statement : Accept_Statement,
          Statements       : Statement_S;       -- statements after the accept
    Delay_Alternative =>
          Guard           : Expression,
          Delay_Statement : Delay_Statement,
          Statements      : Statement_S;
    Terminate_Alternative =>
          Guard : Expression;  -- "when C => terminate;"

    Conditional_Entry_Call =>                   -- [Ada 22 RM 9.7.2]
          Entry_Call      : Entry_Call,
          Call_Statements : Statement_S,  -- statements after the call
          Else_Statements : Statement_S;
    Timed_Entry_Call =>                         -- [Ada 22 RM 9.7.3]
          Entry_Call       : Entry_Call,
          Call_Statements  : Statement_S,
          Delay_Statement  : Delay_Statement,
          Delay_Statements : Statement_S;
    Asynchronous_Select =>                      -- [Ada 22 RM 9.7.4]
          Trigger               : Statement,    -- an entry call or a delay statement
          Triggering_Statements : Statement_S,
          Abortable_Statements  : Statement_S;

    -- 5.6.1 Parallel block statement
    Parallel_Block =>                           -- "parallel do S1 and S2 and ... end do;"
          Arms : Parallel_Arm_S;
    Parallel_Arm =>
          Statements : Statement_S;  -- one parallel sequence of statements


    -- =======================================================================
    -- 3.2 Type specifications (full Ada 2022 type taxonomy)  [Ada 22 RM 3.2]
    --   The Generic_Formal_Type hierarchy (section 12) mirrors this one.
    -- =======================================================================

    Type_Spec ::=
          Scalar_Type
        | Access_Type
        | Composite_Type
        | Derived_Type
        | Class_Wide_Type
        | Private_Type
        | Incomplete_Type
        | Generic_Formal_Type      -- formal types are type specs (parallel tree)
        | Constrained_Spec         -- a subtype_indication used as a type
        | Universal_Type
        | Void;

    Constrained_Spec =>                         -- a subtype_indication
          Mark       : Name,
          Constraint : Constraint;

    Universal_Type    ::= Universal_Integer | Universal_Real | Universal_Fixed;
    Universal_Integer => ;
    Universal_Real    => ;
    Universal_Fixed   => ;

    -- ----- Scalar types -------------------------------------  [Ada 22 RM 3.5]
    Scalar_Type      ::= Discrete_Type | Real_Type;
    Discrete_Type    ::= Enumeration_Type | Integer_Type;
    Integer_Type     ::= Signed_Integer_Type | Modular_Type;
    Real_Type        ::= Floating_Point_Type | Fixed_Point_Type;
    Fixed_Point_Type ::= Ordinary_Fixed_Point_Type | Decimal_Fixed_Point_Type;

    Enumeration_Type =>
          Literals : Defining_Name_S;
    Signed_Integer_Type =>
          Bounds : Range_Bounds;
    Modular_Type =>                             -- [Ada 22 RM 3.5.4]  (Ada 95+)
          Modulus : Expression;
    Floating_Point_Type =>
          Digits_Value     : Expression,
          Real_Range : Scalar_Range;
    Ordinary_Fixed_Point_Type =>
          Delta_Value      : Expression,
          Real_Range : Scalar_Range;
    Decimal_Fixed_Point_Type =>                 -- [Ada 22 RM 3.5.9]
          Delta_Value      : Expression,
          Digits_Value     : Expression,
          Real_Range : Scalar_Range;

    -- ----- Access types ------------------------------------  [Ada 22 RM 3.10]
    Access_Type ::= Access_To_Object | Access_To_Subprogram;
    Object_Access_Kind ::=
          Pool_Specific            -- access T
        | General_Access_All       -- access all T
        | General_Access_Constant; -- access constant T
    Pool_Specific           => ;
    General_Access_All      => ;
    General_Access_Constant => ;
    Access_To_Object        =>
          Designated   : Type_Spec,
          Access_Kind  : Object_Access_Kind,
          Is_Anonymous : Boolean;             -- anonymous access type
    Access_To_Subprogram =>
          Profile      : Header,
          Is_Protected : Boolean,  -- access to protected subprogram
          Is_Anonymous : Boolean;

    -- ----- Composite types -----------------------------  [Ada 22 RM 3.6, 3.8]
    Composite_Type ::=
          Array_Type
        | Record_Type
        | Tagged_Record_Type
        | Interface_Type
        | Task_Type
        | Protected_Type;

    Array_Type =>                               -- [Ada 22 RM 3.6]
          Index_Ranges   : Discrete_Range_S,    -- index subtypes ("T range <>") or index constraints
          Is_Constrained : Boolean,             -- constrained_array_definition vs unconstrained
          Component      : Constrained_Spec;
    Record_Type =>                              -- untagged record
          Components : Component_S;
    Tagged_Record_Type =>                       -- tagged record / record extension  [Ada 22 RM 3.9]
          Ancestor    : Type_Spec,    -- Void for a root tagged type
          Progenitors : Name_S,       -- implemented interfaces
          Components  : Component_S;  -- abstract/limited via Properties aspect
    Interface_Type =>                           -- [Ada 22 RM 3.9.4]
          Progenitors : Name_S,
          Kind        : Interface_Kind;
    Interface_Kind ::=
          Ordinary_Interface
        | Limited_Interface
        | Synchronized_Interface
        | Task_Interface
        | Protected_Interface;
    Ordinary_Interface     => ;
    Limited_Interface      => ;
    Synchronized_Interface => ;
    Task_Interface         => ;
    Protected_Interface    => ;
    Task_Type              =>                                -- [Ada 22 RM 9.1]   (operations: TODO(2022))
          Definition : Task_Definition;
    Protected_Type =>                           -- [Ada 22 RM 9.4]   (operations: TODO(2022))
          Definition : Protected_Definition;
    Protected_Definition ::= Protected_Specification | Void;
    Protected_Specification =>
          Visible_Declarations : Declaration_S,
          Private_Declarations : Declaration_S;

    -- ----- Class-wide, derived, private, incomplete -----------
    Class_Wide_Type =>                          -- T'Class  [Ada 22 RM 3.4.1]
          Root_Type : Type_Spec;
    Derived_Type =>                             -- "new S" (non-extension derivation)
          Parent : Constrained_Spec;
    Private_Type =>                             -- private / limited / tagged private; private extension
          Discriminants : Discriminant_Part,
          Ancestor      : Type_Spec,          -- Void unless a private extension ("new P with private")
          Progenitors   : Name_S,             -- interfaces of a private extension
          Is_Tagged     : Boolean,
          Is_Limited    : Boolean,
          Is_Abstract   : Boolean;
    Incomplete_Type =>                          -- "type T;" / "type T is tagged;"  [Ada 22 RM 3.10.1]
          Is_Tagged : Boolean;

    -- records: components, variants, discriminants            [Ada 22 RM 3.7, 3.8]
    Component ::=
          Component_Declaration
        | Variant_Part
        | Null_Component
        | Component_Pragma;
    Component_Declaration =>                     -- a record component_declaration  [Ada 22 RM 3.8]
          Names          : Defining_Name_S,
          Object_Subtype : Type_Spec,
          Initialization : Expression;       -- Void if none
    Component_Pragma => Pragma : Pragma;         -- a pragma among record components
    Null_Component   => ;
    Variant_Part     =>
          Discriminant : Name,
          Variants     : Variant_S;
    Variant =>
          Choices    : Choice_S,
          Components : Component_S;
    Discriminant_Part ::= Discriminant_S | Void;


    -- =======================================================================
    -- 3.5 Constraints                                       [Ada 22 RM 3.5]
    -- =======================================================================

    Constraint ::=
          Discrete_Range          -- a single range or discrete subtype (range constraint)
        | Index_Constraint        -- "(dr, dr, ...)" — an array index constraint
        | Real_Constraint         -- float / fixed accuracy
        | Discriminant_Constraint
        | Void;
    -- A discrete range nests under Constraint (Constraint > Discrete_Range >
    -- Scalar_Range > Range_Bounds), so each has a single parent.
    Discrete_Range ::= Scalar_Range | Discrete_Subtype;
    Scalar_Range   ::= Range_Bounds | Range_Attribute;
    Range_Bounds =>
          Lower : Expression,
          Upper : Expression;
    Range_Attribute =>                          -- T'Range  /  T'Range(N)
          Prefix : Name;
    Discrete_Subtype =>                          -- a subtype indication used as a discrete range
          Subtype_Indication : Constrained_Spec;
    Index_Constraint =>                          -- (discrete_range, ...)
          Ranges : Discrete_Range_S;
    Real_Constraint ::= Float_Constraint | Fixed_Constraint;
    Float_Constraint        => Digits_Value : Expression, Real_Range : Scalar_Range;  -- Void Real_Range allowed
    Fixed_Constraint        => Delta_Value  : Expression, Real_Range : Scalar_Range;
    Discriminant_Constraint =>
          Associations : Association_S,
          Normalized   : Expression_S;   -- semantic


    -- =======================================================================
    -- 6 / 7 Subprograms, packages, bodies, headers          [Ada 22 RM 6, 7]
    -- =======================================================================

    Header ::= Procedure_Header | Function_Header | Entry_Header;
    Procedure_Header =>
          Parameters : Parameter_S;
    Function_Header =>
          Parameters     : Parameter_S,
          Result_Subtype : Name;         -- Void for instantiation
    Entry_Header =>
          Family_Index : Discrete_Range,  -- Void if not a family
          Parameters   : Parameter_S;

    Subprogram_Declaration =>
          Designator : Defining_Occurrence,
          Header     : Header,
          Completion : Unit_Completion;      -- renaming/instantiation/default, or none
    Subprogram_Body =>
          Designator : Defining_Occurrence,
          Header     : Header,
          Completion : Unit_Completion;      -- a block or stub

    Parameter ::=                               -- [Ada 22 RM 6.1]
          In_Parameter
        | Out_Parameter
        | In_Out_Parameter;
    In_Parameter =>
          Names      : Defining_Name_S,
          Type_Mark  : Parameter_Type,
          Default    : Expression,            -- Void if none
          Is_Aliased : Boolean;
    Out_Parameter =>
          Names      : Defining_Name_S,
          Type_Mark  : Parameter_Type,
          Is_Aliased : Boolean;
    In_Out_Parameter =>
          Names      : Defining_Name_S,
          Type_Mark  : Parameter_Type,
          Is_Aliased : Boolean;
    -- A parameter's type is a subtype mark or an anonymous access definition.
    Parameter_Type ::= Named_Subtype | Anonymous_Access;
    Named_Subtype    => Mark       : Name;
    Anonymous_Access => Definition : Access_Type;   -- "access [all|constant] T" / "access P"

    Package_Declaration =>
          Name       : Defining_Name,
          Completion : Unit_Completion;  -- a package_specification, instantiation, or renaming
    Package_Specification =>
          Visible_Declarations : Declaration_S,
          Private_Declarations : Declaration_S;
    Package_Body =>
          Name       : Defining_Name,
          Completion : Unit_Completion;  -- a block or stub

    -- A program unit's completion. Rev 4 unifies the "spec definition" and the
    -- "body description"; which alternatives are legal in a given position (a bare
    -- spec vs. a body) is a semantic rule, not a structural one.
    Unit_Completion ::=
          Block                       -- a block body (declarations + statements + handlers)
        | Stub                        -- "is separate"
        | Unit_Instantiation          -- "is new G(...)"
        | Unit_Renaming               -- "renames X" / renaming-as-body
        | Formal_Subprogram_Default   -- generic formal subprogram default
        | Language_Binding            -- imported / convention
        | Void;                       -- a spec with no completion
    Block =>
          Declarations : Item_S,
          Statements   : Statement_S,
          Handlers     : Alternative_S;
    Unit_Instantiation => Instance : Generic_Instantiation;   -- the instance's home is Declaration
    Unit_Renaming      => Renamed  : Name;
    Stub               => ;
    Subunit            =>
          Parent     : Name,
          Completion : Proper_Body;  -- a subunit's body is a proper body
    Renaming =>
          Renamed : Name;
    Language_Binding =>
          Convention : Argument_Name;

    -- Tasks  [Ada 22 RM 9.1]  (single tasks and task types; task TYPES are also
    -- Type_Specs — see Task_Type. Entry declarations live in the spec's
    -- Declarations as Subprogram_Declarations with an Entry_Header.)
    Task_Declaration =>
          Name       : Defining_Name,
          Definition : Task_Definition;
    Task_Definition ::= Task_Specification | Void;
    Task_Specification =>
          Declarations : Declaration_S;  -- entry declarations + representation items
    Task_Body =>
          Name : Defining_Name,
          Completion : Unit_Completion;

    -- Protected units  [Ada 22 RM 9.4]  (protected TYPES are Type_Specs — see
    -- Protected_Type. The body holds protected subprograms and entry bodies.)
    Protected_Body =>
          Name       : Defining_Name,
          Operations : Item_S;         -- protected subprograms + entry bodies (legality is semantic)
    Entry_Body =>                               -- [Ada 22 RM 9.5.2]
          Name         : Defining_Name,
          Family_Index : Entry_Index_Specification,  -- Void unless an entry family
          Parameters   : Parameter_S,
          Barrier      : Expression,                 -- the "when <barrier>" condition
          Completion   : Block;                      -- the entry body's block
    Entry_Index_Specification ::= Entry_Index_Definition | Void;
    Entry_Index_Definition =>                   -- "(for I in discrete_range)"
          Parameter      : Defining_Name,
          Discrete_Range : Discrete_Range;


    -- =======================================================================
    -- 12 Generic units (mirror the type/subprogram/package system)
    --                                                       [Ada 22 RM 12]
    -- =======================================================================

    Generic_Declaration =>
          Name          : Defining_Name,
          Formals       : Generic_Formal_S,
          Specification : Generic_Header;
    Generic_Header ::= Generic_Subprogram_Header | Package_Specification;
    Generic_Subprogram_Header => Profile : Header;  -- a generic procedure/function profile

    -- Generic formal part. Each formal is a wrapper node that *references* the
    -- shared declaration/type nodes via attributes (so Generic_Formal_Type stays
    -- solely a Type_Spec, and nothing is multiply class-membered).  [Ada 22 RM 12.1]
    Generic_Formal ::=
          Generic_Formal_Object
        | Generic_Formal_Type_Declaration
        | Generic_Formal_Subprogram
        | Generic_Formal_Package;

    Generic_Formal_Object =>                    -- [Ada 22 RM 12.4]
          Names        : Defining_Name_S,
          Mode         : Generic_Object_Mode,
          Subtype_Mark : Name,
          Default      : Expression;           -- Void if none
    Generic_Object_Mode ::= Generic_In | Generic_In_Out;
    Generic_In     => ;
    Generic_In_Out => ;

    Generic_Formal_Type_Declaration =>          -- [Ada 22 RM 12.5]
          Name       : Defining_Name,
          Definition : Generic_Formal_Type;  -- a Type_Spec (see below)

    Generic_Formal_Subprogram =>                -- [Ada 22 RM 12.6]
          Specification : Subprogram_Declaration,     -- referenced, not membered
          Default       : Formal_Subprogram_Default;
    Formal_Subprogram_Default ::=               -- "is Name" | "is <>" | (none)
          Default_Name
        | Box
        | No_Default;
    Default_Name => Subprogram : Name;          -- the default subprogram
    Box          => ;
    No_Default   => ;

    Generic_Formal_Package =>                   -- [Ada 22 RM 12.7]
          Name     : Defining_Name,
          Template : Name,           -- the named generic package
          Actuals  : Association_S,  -- explicit actuals (empty if box)
          Is_Box   : Boolean;        -- "(<>)" — matches any instance

    -- ----- Generic formal types (MIRROR of the Type_Spec hierarchy) ----------
    --   Scalar formals are "open" (<>) markers; structured formals carry the
    --   same shape as their actual counterparts.                  [Ada 22 RM 12.5]
    Generic_Formal_Type ::=
          Formal_Scalar_Type        -- mirrors Scalar_Type
        | Formal_Access_Type        -- mirrors Access_Type
        | Formal_Composite_Type     -- mirrors Composite_Type
        | Formal_Derived_Type       -- mirrors Derived_Type
        | Formal_Private_Type       -- mirrors Private_Type
        | Formal_Incomplete_Type;   -- mirrors Incomplete_Type

    Formal_Scalar_Type ::=                      -- [Ada 22 RM 12.5.2]
          Formal_Discrete                       -- type T is (<>);
        | Formal_Signed_Integer                 -- type T is range <>;
        | Formal_Modular                        -- type T is mod <>;
        | Formal_Floating_Point                 -- type T is digits <>;
        | Formal_Ordinary_Fixed                 -- type T is delta <>;
        | Formal_Decimal_Fixed;                 -- type T is delta <> digits <>;
    Formal_Discrete       => ;
    Formal_Signed_Integer => ;
    Formal_Modular        => ;
    Formal_Floating_Point => ;
    Formal_Ordinary_Fixed => ;
    Formal_Decimal_Fixed  => ;

    Formal_Access_Type ::= Formal_Access_To_Object | Formal_Access_To_Subprogram;  -- [Ada 22 RM 12.5.4]
    Formal_Access_To_Object =>
          Designated  : Type_Spec,
          Access_Kind : Object_Access_Kind;
    Formal_Access_To_Subprogram =>
          Profile : Header;

    Formal_Composite_Type ::= Formal_Array_Type | Formal_Interface_Type;   -- [Ada 22 RM 12.5.3]
    Formal_Array_Type =>
          Index_Ranges : Discrete_Range_S,
          Component    : Constrained_Spec;
    Formal_Interface_Type =>                    -- [Ada 22 RM 12.5.5]
          Progenitors : Name_S,
          Kind        : Interface_Kind;

    Formal_Derived_Type =>                      -- "new S [and I..] [with private]"  [Ada 22 RM 12.5.1]
          Parent          : Constrained_Spec,
          Progenitors     : Name_S,
          Is_Tagged       : Boolean,
          Is_Limited      : Boolean,
          Is_Abstract     : Boolean,
          Is_Synchronized : Boolean;
    Formal_Private_Type =>                      -- "[abstract] [tagged] [limited] private"
          Discriminants   : Discriminant_Part,
          Is_Tagged       : Boolean,
          Is_Limited      : Boolean,
          Is_Abstract     : Boolean,
          Is_Synchronized : Boolean;
    Formal_Incomplete_Type =>                   -- "type T;" / "type T is tagged;" (formal)  [Ada 22 RM 12.5]
          Is_Tagged : Boolean;

    Generic_Instantiation =>
          Generic_Unit          : Name,                                                       -- structural
          Associations          : Association_S,                                              -- structural
          Expanded_Declarations : Declaration_S;-- semantic (the instantiated spec)  [DIANA]


    -- =======================================================================
    -- Aspects & attribute-definition clauses → ONE construct         [Instr]
    --   "with Size => 8" and "for T'Size use 8;" both become a Semantic_Property,
    --   distinguished only by Origin (plus the inherited Source_Position).
    -- =======================================================================

    Semantic_Property =>
          Identity   : Property_Identity,  -- structural (which property; see below)
          Class_Wide : Boolean,            -- structural (the 'Class form: Pre'Class, ...)
          Value      : Property_Value,     -- structural (Void = boolean aspect, defaults True)
          Origin     : Property_Origin;    -- structural (aspect vs attribute clause)
    Property_Origin ::= From_Aspect | From_Attribute_Clause;
    From_Aspect           => ;
    From_Attribute_Clause => ;

    -- A property value is usually an expression; Contract_Cases is structured;
    -- boolean aspects (Pack, Atomic, Inline, ...) carry Void and default to True.
    Property_Value ::= Aspect_Expression | Contract_Case_List | Void;
    Aspect_Expression  => Value : Expression;    -- the usual aspect/attribute value
    Contract_Case_List =>                       -- [Ada 22 RM 6.1.1]
          Cases : Contract_Case_S;
    Contract_Case =>
          Guard       : Expression,  -- the condition; Void = "others"
          Consequence : Expression;

    -- Recognized aspects / attribute-definition properties.  "Aspect_X" denotes
    -- the semantic property X however it was written (aspect specification OR
    -- attribute_definition clause); Origin records the syntactic form and
    -- Class_Wide selects the 'Class variant.  Implementation-defined or
    -- unrecognized properties use Other_Property (which keeps the source name).
    Property_Identity ::=
          Contract_Aspect
        | Representation_Aspect
        | Interfacing_Aspect
        | Categorization_Aspect
        | Concurrency_Aspect
        | Iteration_Aspect
        | Literal_Aspect
        | Stream_Aspect
        | Other_Property;

    Other_Property =>
          Property_Name : Name;  -- the source aspect/attribute name

    -- Assertions & contracts    [Ada 22 RM 13.1.1, 6.1.1, 6.1.2, 7.3.2, 7.3.3]
    Contract_Aspect ::=
          Aspect_Pre
        | Aspect_Post
        | Aspect_Type_Invariant
        | Aspect_Predicate 
        | Aspect_Static_Predicate 
        | Aspect_Dynamic_Predicate
        | Aspect_Contract_Cases 
        | Aspect_Default_Initial_Condition
        | Aspect_Subprogram_Variant            -- Ada 2022
        | Aspect_Global                        -- Ada 2022
        | Aspect_Depends
        | Aspect_Relaxed_Initialization        -- Ada 2022
        | Aspect_Stable_Properties;            -- Ada 2022
    Aspect_Pre                       => ;
    Aspect_Post                      => ;
    Aspect_Type_Invariant            => ;
    Aspect_Predicate                 => ;
    Aspect_Static_Predicate          => ;
    Aspect_Dynamic_Predicate         => ;
    Aspect_Contract_Cases            => ;
    Aspect_Default_Initial_Condition => ;
    Aspect_Subprogram_Variant        => ;
    Aspect_Global                    => ;
    Aspect_Depends                   => ;
    Aspect_Relaxed_Initialization    => ;
    Aspect_Stable_Properties         => ;

    -- Representation                                   [Ada 22 RM 13.1 .. 13.3]
    Representation_Aspect ::=
          Aspect_Size 
        | Aspect_Object_Size 
        | Aspect_Component_Size
        | Aspect_Alignment 
        | Aspect_Bit_Order 
        | Aspect_Scalar_Storage_Order
        | Aspect_Pack 
        | Aspect_Address 
        | Aspect_Storage_Size
        | Aspect_Storage_Pool 
        | Aspect_Default_Storage_Pool
        | Aspect_Small 
        | Aspect_Machine_Radix
        | Aspect_Default_Value 
        | Aspect_Default_Component_Value
        | Aspect_Atomic 
        | Aspect_Volatile
        | Aspect_Atomic_Components 
        | Aspect_Volatile_Components
        | Aspect_Independent 
        | Aspect_Independent_Components
        | Aspect_External_Tag 
        | Aspect_Discard_Names;
    Aspect_Size                    => ;
    Aspect_Object_Size             => ;
    Aspect_Component_Size          => ;
    Aspect_Alignment               => ;
    Aspect_Bit_Order               => ;
    Aspect_Scalar_Storage_Order    => ;
    Aspect_Pack                    => ;
    Aspect_Address                 => ;
    Aspect_Storage_Size            => ;
    Aspect_Storage_Pool            => ;
    Aspect_Default_Storage_Pool    => ;
    Aspect_Small                   => ;
    Aspect_Machine_Radix           => ;
    Aspect_Default_Value           => ;
    Aspect_Default_Component_Value => ;
    Aspect_Atomic                  => ;
    Aspect_Volatile                => ;
    Aspect_Atomic_Components       => ;
    Aspect_Volatile_Components     => ;
    Aspect_Independent             => ;
    Aspect_Independent_Components  => ;
    Aspect_External_Tag            => ;
    Aspect_Discard_Names           => ;

    -- Interfacing                                            [Ada 22 RM B.1]
    Interfacing_Aspect ::=
          Aspect_Convention 
        | Aspect_Import 
        | Aspect_Export
        | Aspect_External_Name 
        | Aspect_Link_Name;
    Aspect_Convention    => ;
    Aspect_Import        => ;
    Aspect_Export        => ;
    Aspect_External_Name => ;
    Aspect_Link_Name     => ;

    -- Categorization & subprogram                       [Ada 22 RM 10.2.1, 6.3]
    Categorization_Aspect ::=
          Aspect_Pure
        | Aspect_Preelaborate 
        | Aspect_Elaborate_Body
        | Aspect_Remote_Types 
        | Aspect_Remote_Call_Interface 
        | Aspect_Shared_Passive
        | Aspect_Inline 
        | Aspect_No_Return;
    Aspect_Pure                  => ;
    Aspect_Preelaborate          => ;
    Aspect_Elaborate_Body        => ;
    Aspect_Remote_Types          => ;
    Aspect_Remote_Call_Interface => ;
    Aspect_Shared_Passive        => ;
    Aspect_Inline                => ;
    Aspect_No_Return             => ;

    -- Concurrency & real-time                              [Ada 22 RM D, C.3]
    Concurrency_Aspect ::=
          Aspect_Priority 
        | Aspect_Interrupt_Priority 
        | Aspect_CPU
        | Aspect_Dispatching_Domain 
        | Aspect_Attach_Handler
        | Aspect_Interrupt_Handler 
        | Aspect_Exclusive_Functions;
    Aspect_Priority            => ;
    Aspect_Interrupt_Priority  => ;
    Aspect_CPU                 => ;
    Aspect_Dispatching_Domain  => ;
    Aspect_Attach_Handler      => ;
    Aspect_Interrupt_Handler   => ;
    Aspect_Exclusive_Functions => ;

    -- Iteration & indexing                       [Ada 22 RM 4.1.6, 5.5.1, 4.3.5]
    Iteration_Aspect ::=
          Aspect_Constant_Indexing 
        | Aspect_Variable_Indexing
        | Aspect_Default_Iterator 
        | Aspect_Iterator_Element
        | Aspect_Iterator_View 
        | Aspect_Aggregate 
        | Aspect_Iterable;
    Aspect_Constant_Indexing => ;
    Aspect_Variable_Indexing => ;
    Aspect_Default_Iterator  => ;
    Aspect_Iterator_Element  => ;
    Aspect_Iterator_View     => ;
    Aspect_Aggregate         => ;
    Aspect_Iterable          => ;

    -- User-defined literals                                 [Ada 22 RM 4.2.1]
    Literal_Aspect ::=
          Aspect_Integer_Literal 
        | Aspect_Real_Literal 
        | Aspect_String_Literal;
    Aspect_Integer_Literal => ;
    Aspect_Real_Literal    => ;
    Aspect_String_Literal  => ;

    -- Streams & image                                  [Ada 22 RM 13.13.2, 4.10]
    Stream_Aspect ::=
          Aspect_Read
        | Aspect_Write 
        | Aspect_Input 
        | Aspect_Output
        | Aspect_Put_Image;                    -- Put_Image: Ada 2022
    Aspect_Read      => ;
    Aspect_Write     => ;
    Aspect_Input     => ;
    Aspect_Output    => ;
    Aspect_Put_Image => ;

    -- Representation clauses that are NOT aspect-equivalent (record layout, ...)
    Representation_Clause ::=                    -- [Ada 22 RM 13]
          Record_Representation
        | Address_Clause
        | Code_Statement;
    Record_Representation =>
          Name           : Name,
          Alignment      : Expression,
          Component_Reps : Component_Rep_S;
    Component_Rep =>
          Name      : Name,
          Position  : Expression,
          Bit_Range : Range_Bounds;
    Address_Clause =>
          Name    : Name,
          Address : Expression;
    Code_Statement =>
          Subtype_Mark : Name,
          Aggregate    : Expression;


    -- =======================================================================
    -- Pragmas                                               [Ada 22 RM 2.8]
    -- =======================================================================

    Pragma =>                                   -- the pragma content
          Name      : Name,
          Arguments : Association_S;
    -- Per-position pragma wrappers: a pragma must be a member of each list's
    -- class, so each position gets a thin wrapper over the shared Pragma content.
    Statement_Pragma          => Pragma : Pragma;
    Context_Pragma            => Pragma : Pragma;
    Alternative_Pragma        => Pragma : Pragma;
    Select_Alternative_Pragma => Pragma : Pragma;
    Context_Use_Clause        => Names  : Name_S;   -- a use clause in a context clause


    -- =======================================================================
    -- Operators  (the "Operator" private type's value set; encoded as the
    -- Prefix of a Function_Call). Carried over from Rev 3 OP_CLASS.   [DIANA]
    -- =======================================================================

    Operator ::=
          Op_And
        | Op_Or 
        | Op_Xor
        | Op_Equal 
        | Op_Not_Equal
        | Op_Less 
        | Op_Less_Equal 
        | Op_Greater 
        | Op_Greater_Equal
        | Op_Plus 
        | Op_Minus 
        | Op_Concatenate
        | Op_Unary_Plus 
        | Op_Unary_Minus
        | Op_Absolute 
        | Op_Not
        | Op_Multiply 
        | Op_Divide 
        | Op_Modulo 
        | Op_Remainder 
        | Op_Exponentiate;
    Op_And           => ;
    Op_Or            => ;
    Op_Xor           => ;
    Op_Equal         => ;
    Op_Not_Equal     => ;
    Op_Less          => ;
    Op_Less_Equal    => ;
    Op_Greater       => ;
    Op_Greater_Equal => ;
    Op_Plus          => ;
    Op_Minus         => ;
    Op_Concatenate   => ;
    Op_Unary_Plus    => ;
    Op_Unary_Minus   => ;
    Op_Absolute      => ;
    Op_Not           => ;
    Op_Multiply      => ;
    Op_Divide        => ;
    Op_Modulo        => ;
    Op_Remainder     => ;
    Op_Exponentiate  => ;


    -- =======================================================================
    -- Static-value model (external rep of the Value private type)    [DIANA]
    -- =======================================================================

    Static_Value ::=
          No_Value
        | String_Value
        | Boolean_Value
        | Integer_Value
        | Real_Value;
    No_Value      => ;
    String_Value  => Text   : String;
    Boolean_Value => Flag   : Boolean;
    Integer_Value => Whole  : Integer;
    Real_Value    => Number : Rational;


    -- =======================================================================
    -- The universal empty node                                      [DIANA]
    -- =======================================================================

    Void => ;


    -- =======================================================================
    -- Sequence carriers ("_S"), grouped under Element_List          [DIANA]
    -- =======================================================================

    Element_List ::=
          Compilation_Unit_S
        | Context_Element_S
        | Declaration_S
        | Item_S
        | Defining_Name_S
        | Name_S
        | Expression_S
        | Association_S
        | Statement_S
        | Alternative_S
        | Choice_S
        | Membership_Choice_S
        | Conditional_Clause_S
        | Expression_Clause_S
        | Expression_Alternative_S
        | Select_Alternative_S
        | Parallel_Arm_S
        | Contract_Case_S
        | Component_S
        | Variant_S
        | Discrete_Range_S
        | Parameter_S
        | Generic_Formal_S
        | Component_Rep_S
        | Semantic_Property_S;

    Compilation_Unit_S  => List : Seq Of Compilation_Unit;
    Context_Element_S   => List : Seq Of Context_Element;
    Declaration_S       => List : Seq Of Declaration;
    Item_S              => List : Seq Of Item;
    Defining_Name_S     => List : Seq Of Defining_Name;
    Name_S              => List : Seq Of Name;
    Expression_S        => List : Seq Of Expression;
    Association_S       => List : Seq Of Association;
    Statement_S         => List : Seq Of Statement;
    Alternative_S       => List : Seq Of Alternative;
    Choice_S            => List : Seq Of Choice;
    Membership_Choice_S => List : Seq Of Membership_Choice;
    
    Choice ::=
          Choice_Expression
        | Choice_Range
        | Others_Choice;
        
    Choice_Expression        => Value : Expression;     -- a single value choice
    Choice_Range             => Range : Discrete_Range; -- a discrete-range choice
    Others_Choice            => ;
    
    Conditional_Clause_S     => List : Seq Of Conditional_Clause;
    Expression_Clause_S      => List : Seq Of Expression_Clause;
    Expression_Alternative_S => List : Seq Of Expression_Alternative;
    Select_Alternative_S     => List : Seq Of Select_Alternative;
    Parallel_Arm_S           => List : Seq Of Parallel_Arm;
    Contract_Case_S          => List : Seq Of Contract_Case;
    Component_S              => List : Seq Of Component;
    Variant_S                => List : Seq Of Variant;
    Discriminant_S           => List : Seq Of Discriminant;
    Discriminant             =>
          Names        : Defining_Name_S,
          Subtype_Mark : Name,
          Default      : Expression;
    Discrete_Range_S    => List : Seq Of Discrete_Range;
    Parameter_S         => List : Seq Of Parameter;
    Generic_Formal_S    => List : Seq Of Generic_Formal;
    Component_Rep_S     => List : Seq Of Component_Rep;
    Semantic_Property_S => List : Seq Of Semantic_Property;


    -- =======================================================================
    -- Optional ("_Void") helper classes
    -- =======================================================================


End;
